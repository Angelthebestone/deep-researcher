{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operation_record.schema.json",
  "title": "OperationRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation_id",
    "operation_type",
    "subject_id",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "operation_type": {
      "type": "string",
      "enum": ["research", "analysis"]
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "type": "string"
    },
    "event_count": {
      "type": "integer",
      "minimum": 0
    }
  }
}
