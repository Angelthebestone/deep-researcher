{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "analysis_stream_event.schema.json",
  "title": "AnalysisStreamEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "sequence",
    "operation_id",
    "operation_type",
    "operation_status",
    "event_type",
    "message",
    "document_id",
    "idempotency_key",
    "details"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "operation_type": {
      "type": "string",
      "enum": ["research", "analysis"]
    },
    "operation_status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "stage_context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stage"],
      "properties": {
        "stage": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "fallback_reason": {
          "type": "string",
          "enum": [
            "timeout",
            "invalid_json",
            "empty_response",
            "provider_failure",
            "grounded_postprocess",
            "planner_fallback",
            "gemini_timeout_to_mistral",
            "empty_local_fallback",
            "invalid_local_fallback"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "failed_stage": {
          "type": "string"
        },
        "breadth": {
          "type": "integer",
          "minimum": 1
        },
        "depth": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "report_markdown": {
      "type": "string"
    },
    "report_artifact": {
      "$ref": "technology_report.schema.json"
    }
  }
}
