{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technology_mention.schema.json",
  "title": "TechnologyMention",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mention_id",
    "document_id",
    "source_type",
    "page_number",
    "raw_text",
    "technology_name",
    "normalized_name",
    "category",
    "confidence",
    "evidence_spans",
    "source_uri"
  ],
  "properties": {
    "mention_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": ["pdf", "image", "docx", "pptx", "sheet", "text"]
    },
    "page_number": {
      "type": "integer",
      "minimum": 0
    },
    "raw_text": {
      "type": "string",
      "minLength": 1
    },
    "technology_name": {
      "type": "string",
      "minLength": 1
    },
    "normalized_name": {
      "type": "string",
      "minLength": 1
    },
    "vendor": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["language", "framework", "database", "cloud", "tool", "other"]
    },
    "version": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_spans": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EvidenceSpan"
      }
    },
    "context": {
      "type": "string"
    },
    "source_uri": {
      "type": "string"
    }
  },
  "$defs": {
    "EvidenceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "page_number", "start_char", "end_char", "text", "evidence_type"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "page_number": {
          "type": "integer",
          "minimum": 0
        },
        "start_char": {
          "type": "integer",
          "minimum": 0
        },
        "end_char": {
          "type": "integer",
          "minimum": 0
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "type": "string",
          "enum": ["text", "ocr", "table", "figure", "caption"]
        }
      }
    }
  }
}
