{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research_plan.schema.json",
  "title": "ResearchPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "query",
    "target_technology",
    "breadth",
    "depth",
    "execution_mode",
    "plan_summary",
    "branches",
    "consolidation_model"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "target_technology": {
      "type": "string",
      "minLength": 1
    },
    "breadth": {
      "type": "integer",
      "minimum": 1
    },
    "depth": {
      "type": "integer",
      "minimum": 1
    },
    "execution_mode": {
      "type": "string",
      "enum": ["serial"]
    },
    "plan_summary": {
      "type": "string",
      "minLength": 1
    },
    "branches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ResearchPlanBranch"
      }
    },
    "consolidation_model": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "ResearchPlanBranch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_id",
        "provider",
        "objective",
        "queries",
        "max_iterations",
        "search_model",
        "review_model",
        "embedding_model"
      ],
      "properties": {
        "branch_id": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "enum": ["gemini_grounded", "mistral_web_search"]
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "queries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "search_model": {
          "type": "string",
          "minLength": 1
        },
        "review_model": {
          "type": "string",
          "minLength": 1
        },
        "embedding_model": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
