{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operation_event.schema.json",
  "title": "OperationEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "sequence",
    "operation_id",
    "operation_type",
    "status",
    "created_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "operation_type": {
      "type": "string",
      "enum": ["research", "analysis"]
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "message": {
      "type": "string"
    },
    "node_name": {
      "type": "string"
    },
    "event_key": {
      "type": "string"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
